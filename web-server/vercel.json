{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "src/main.rs",
      "use": "vercel-rust"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "src/main.rs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}


