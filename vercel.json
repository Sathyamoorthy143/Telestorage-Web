{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "src/main.rs",
      "use": "vercel-rust",
      "config": { "maxDuration": 60 }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/main.rs"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "frontend/index.html"
    }
  ]
}
